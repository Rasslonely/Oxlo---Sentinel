# Oxlo-Sentinel - Environment Variables Configuration
# Copy this file to .env and fill in the values.

# --- Telegram ---
# Obtain from https://t.me/BotFather
TELEGRAM_BOT_TOKEN=

# --- Oxlo AI ---
# Obtain from https://oxlo.ai/ (API dashboard)
OXLO_API_KEY=
OXLO_BASE_URL=https://api.oxlo.ai/v1

# --- E2B Sandbox ---
# Obtain from https://e2b.dev (API dashboard)
E2B_API_KEY=

# --- Database / Supabase ---
# Obtain from https://supabase.com/ (Project Settings -> API / Database)
SUPABASE_URL=
SUPABASE_ANON_KEY=
DATABASE_URL= # postgresql+asyncpg://user:password@host:5432/dbname

# --- App Settings ---
MAX_AUDIT_CYCLES=3
RATE_LIMIT_PER_MINUTE=5
SANDBOX_TTL_SECONDS=600
LOG_LEVEL=INFO
